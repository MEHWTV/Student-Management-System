#include <iostream>
#include <string>
using namespace std;

struct Student
{
    int id;
    string name;
    float marks;
};

int main()
{
    Student s[3];

    for (int i = 0; i < 3; i++)
    {
        cout << "Enter Student " << i + 1 << " ID: ";
        cin >> s[i].id;

        cout << "Enter Student " << i + 1 << " Name: ";
        cin >> s[i].name;

        cout << "Enter Student " << i + 1 << " Marks: ";
        cin >> s[i].marks;

        cout << endl;
    }

    cout << "\n--- Student Information ---\n";

    for (int i = 0; i < 3; i++)
    {
        cout << "\nStudent " << i + 1 << endl;
        cout << "ID: " << s[i].id << endl;
        cout << "Name: " << s[i].name << endl;
        cout << "Marks: " << s[i].marks << endl;
    }

    int highest = 0;

    for (int i = 1; i < 3; i++)
    {
        if (s[i].marks > s[highest].marks)
        {
            highest = i;
        }
    }

    cout << "\n--- Top Student ---\n";
    cout << "Name: " << s[highest].name << endl;
    cout << "Marks: " << s[highest].marks << endl;

    return 0;
}